generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model QuoteRequest {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String
  vehicleMake  String
  vehicleModel String
  vehicleYear  String
  service   String
  message   String?
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Appointment {
  id           String   @id @default(cuid())
  name         String
  email        String
  phone        String
  vehicleMake  String
  vehicleModel String
  vehicleYear  String
  service      String
  preferredDate    String
  preferredTime    String
  message      String?
  status       String   @default("pending")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
